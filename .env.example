# DigitalOcean Spaces (S3-compatible object storage) — used as the bronze/silver Parquet lake
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=https://sfo2.digitaloceanspaces.com
DO_SPACES_BUCKET=your_bucket_name

# Postgres warehouse (gold layer / star schema) — DigitalOcean managed Postgres in this project
PG_HOST=your-db-host.db.ondigitalocean.com
PG_PORT=25060
PG_DATABASE=defaultdb
PG_USER=doadmin
PG_PASSWORD=your_password
PG_SSLMODE=require